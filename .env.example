# ==============================================================================
# Figma Integration
# ==============================================================================
# Your Personal Access Token (get at figma.com/settings)
FIGMA_TOKEN=figd_xxxxxxxxxxxxxxxxxxxx
# The ID found in your Figma file URL: figma.com/file/FILE_KEY/...
FIGMA_FILE_KEY=ABCDEF1234567890

# ==============================================================================
# Snapshot Storage & Diffing
# ==============================================================================
# Path relative to the monorepo root. Defaults to ./snapshots
SNAPSHOTS_DIR=./snapshots

# Diff sensitivity (0.0 to 1.0). Lower = more sensitive. Default: 0.1
DIFF_THRESHOLD=0.1

# ==============================================================================
# Playwright Test Runner
# ==============================================================================
# The local or staging URL of the web app to be tested
BASE_URL=http://localhost:3000

# If true, runs will overwrite existing Figma/Web baselines instead of diffing
UPDATE_BASELINE=false

# Note: BUILD_ID and PROJECT_ID are injected automatically by the 
# dashboard API during test execution. Do not set them manually here.

# ==============================================================================
# Dashboard (Next.js)
# ==============================================================================
# The proxy route used to serve images from SNAPSHOTS_DIR to the browser
NEXT_PUBLIC_SNAPSHOTS_BASE=/api/image

# ==============================================================================
# AI Analysis (OpenAI-Compatible Vision API)
# ==============================================================================
# The system supports any OpenAI-compatible endpoint (OpenAI, Groq, Gemini, etc.)

# Option A: Google Gemini (Recommended Free Tier)
AI_API_KEY=your-gemini-key
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
AI_MODEL=gemini-1.5-flash

# Option B: OpenAI (Standard)
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AI_API_URL=https://api.openai.com/v1/chat/completions
# AI_MODEL=gpt-4o

# Option C: Groq (High Speed)
# AI_API_KEY=your-groq-key
# AI_API_URL=https://api.groq.com/openai/v1/chat/completions
# AI_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct